{
  "manifest_version": 3,
  "name": "T-Dog's AdBlocker",
  "version": "1.2.0",
  "description": "Lightweight, dependency-free ad & tracker blocker by Nelson Agentic. Native declarativeNetRequest, zero per-request JavaScript.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "111",
  "permissions": [
    "declarativeNetRequest",
    "activeTab",
    "storage",
    "alarms"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ads",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
